# Get these from your Supabase project: Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key       # sb_publishable_...
SUPABASE_SECRET_KEY=your-secret-key                       # sb_secret_...  (server only, never NEXT_PUBLIC_)

# Get these from your Stripe dashboard (Test mode while developing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...                                  # the recurring price you create for the subscription
STRIPE_WEBHOOK_SECRET=whsec_...                             # from `stripe listen` locally, or the webhook endpoint in prod

NEXT_PUBLIC_SITE_URL=http://localhost:3000
